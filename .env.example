# Environment Variables — Copy this to .env and fill in your values
# NEVER commit .env to version control

# ── Groq LLM ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama3-70b-8192
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ── Pipeline ──────────────────────────────────────────────────
# Number of restaurant candidates sent to the LLM
FILTER_TOP_N=10
# Number of final recommendations shown to the user
OUTPUT_TOP_K=5
